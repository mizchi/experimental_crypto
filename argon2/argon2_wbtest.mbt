// Whitebox tests: validate internals (BLAKE2b, G, H') in isolation.

///|
test "blake2b: RFC 7693 §B.1 vector — abc → 64 bytes" {
  // input "abc" (3 bytes)
  let input : FixedArray[Byte] = [b'a', b'b', b'c']
  let out = blake2b(input, 64, FixedArray::make(0, b'\x00'))
  let expected : FixedArray[Byte] = [
    0xBA, 0x80, 0xA5, 0x3F, 0x98, 0x1C, 0x4D, 0x0D, 0x6A, 0x27, 0x97, 0xB6, 0x9F,
    0x12, 0xF6, 0xE9, 0x4C, 0x21, 0x2F, 0x14, 0x68, 0x5A, 0xC4, 0xB7, 0x4B, 0x12,
    0xBB, 0x6F, 0xDB, 0xFF, 0xA2, 0xD1, 0x7D, 0x87, 0xC5, 0x39, 0x2A, 0xAB, 0x79,
    0x2D, 0xC2, 0x52, 0xD5, 0xDE, 0x45, 0x33, 0xCC, 0x95, 0x18, 0xD3, 0x8A, 0xA8,
    0xDB, 0xF1, 0x92, 0x5A, 0xB9, 0x23, 0x86, 0xED, 0xD4, 0x00, 0x99, 0x23,
  ]
  for i in 0..<64 {
    assert_eq(out[i], expected[i])
  }
}

///|
test "blake2b: empty input → 64 bytes (known constant)" {
  // BLAKE2b("") = 786A02F742015903C6C6FD852552D272912F4740E15847618A86E217F71F5419
  //               D25E1031AFEE585313896444934EB04B903A685B1448B755D56F701AFE9BE2CE
  let input = FixedArray::make(0, b'\x00')
  let out = blake2b(input, 64, FixedArray::make(0, b'\x00'))
  let expected : FixedArray[Byte] = [
    0x78, 0x6A, 0x02, 0xF7, 0x42, 0x01, 0x59, 0x03, 0xC6, 0xC6, 0xFD, 0x85, 0x25,
    0x52, 0xD2, 0x72, 0x91, 0x2F, 0x47, 0x40, 0xE1, 0x58, 0x47, 0x61, 0x8A, 0x86,
    0xE2, 0x17, 0xF7, 0x1F, 0x54, 0x19, 0xD2, 0x5E, 0x10, 0x31, 0xAF, 0xEE, 0x58,
    0x53, 0x13, 0x89, 0x64, 0x44, 0x93, 0x4E, 0xB0, 0x4B, 0x90, 0x3A, 0x68, 0x5B,
    0x14, 0x48, 0xB7, 0x55, 0xD5, 0x6F, 0x70, 0x1A, 0xFE, 0x9B, 0xE2, 0xCE,
  ]
  for i in 0..<64 {
    assert_eq(out[i], expected[i])
  }
}

///|
test "argon2: H0 for RFC 9106 §5.3 (Argon2id) matches spec" {
  // Inputs from §5.3: 32B password 0x01, 16B salt 0x02, 8B secret 0x03,
  // 12B ad 0x04. m=32, t=3, p=4, out=32, version=0x13, type=Argon2id.
  let password = Bytes::makei(32, fn(_) { b'\x01' })
  let salt = Bytes::makei(16, fn(_) { b'\x02' })
  let secret = Bytes::makei(8, fn(_) { b'\x03' })
  let ad = Bytes::makei(12, fn(_) { b'\x04' })
  let params : Params = {
    variant: Argon2id,
    m_cost: 32,
    t_cost: 3,
    parallelism: 4,
    output_len: 32,
  }
  let h0 = compute_h0(params, password, salt, secret, ad)
  let expected : FixedArray[Byte] = [
    0x28, 0x89, 0xde, 0x48, 0x7e, 0xb4, 0x2a, 0xe5, 0x00, 0xc0, 0x00, 0x7e, 0xd9,
    0x25, 0x2f, 0x10, 0x69, 0xea, 0xde, 0xc4, 0x0d, 0x57, 0x65, 0xb4, 0x85, 0xde,
    0x6d, 0xc2, 0x43, 0x7a, 0x67, 0xb8, 0x54, 0x6a, 0x2f, 0x0a, 0xcc, 0x1a, 0x08,
    0x82, 0xdb, 0x8f, 0xcf, 0x74, 0x71, 0x4b, 0x47, 0x2e, 0x94, 0xdf, 0x42, 0x1a,
    0x5d, 0xa1, 0x11, 0x2f, 0xfa, 0x11, 0x43, 0x43, 0x70, 0xa1, 0xe9, 0x97,
  ]
  for i in 0..<64 {
    assert_eq(h0[i], expected[i])
  }
}

///|
test "argon2: B[0][0] = H'(H0||LE32(0)||LE32(0), 1024) matches reference" {
  // Compute B[0][0] for §5.3 inputs.
  let h0 : FixedArray[Byte] = [
    0x28, 0x89, 0xde, 0x48, 0x7e, 0xb4, 0x2a, 0xe5, 0x00, 0xc0, 0x00, 0x7e, 0xd9,
    0x25, 0x2f, 0x10, 0x69, 0xea, 0xde, 0xc4, 0x0d, 0x57, 0x65, 0xb4, 0x85, 0xde,
    0x6d, 0xc2, 0x43, 0x7a, 0x67, 0xb8, 0x54, 0x6a, 0x2f, 0x0a, 0xcc, 0x1a, 0x08,
    0x82, 0xdb, 0x8f, 0xcf, 0x74, 0x71, 0x4b, 0x47, 0x2e, 0x94, 0xdf, 0x42, 0x1a,
    0x5d, 0xa1, 0x11, 0x2f, 0xfa, 0x11, 0x43, 0x43, 0x70, 0xa1, 0xe9, 0x97,
  ]
  let prefix = FixedArray::make(72, b'\x00')
  for i in 0..<64 {
    prefix[i] = h0[i]
  }
  // bytes 64..71 are LE32(0) LE32(0) = all zeros
  let block = h_prime(prefix, 1024)
  // First 8 bytes should be: 43 bd 71 06 f1 09 2e 6b
  let expected_head : FixedArray[Byte] = [
    0x43, 0xbd, 0x71, 0x06, 0xf1, 0x09, 0x2e, 0x6b,
  ]
  for i in 0..<8 {
    assert_eq(block[i], expected_head[i])
  }
}

///|
test "blake2b: output length 32 truncates correctly" {
  // BLAKE2b-256("") = 0E5751C026E543B2E8AB2EB06099DAA1D1E5DF47778F7787FAAB45CDF12FE3A8
  let input = FixedArray::make(0, b'\x00')
  let out = blake2b(input, 32, FixedArray::make(0, b'\x00'))
  let expected : FixedArray[Byte] = [
    0x0E, 0x57, 0x51, 0xC0, 0x26, 0xE5, 0x43, 0xB2, 0xE8, 0xAB, 0x2E, 0xB0, 0x60,
    0x99, 0xDA, 0xA1, 0xD1, 0xE5, 0xDF, 0x47, 0x77, 0x8F, 0x77, 0x87, 0xFA, 0xAB,
    0x45, 0xCD, 0xF1, 0x2F, 0xE3, 0xA8,
  ]
  for i in 0..<32 {
    assert_eq(out[i], expected[i])
  }
}
