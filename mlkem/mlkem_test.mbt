// ML-KEM-768 known-answer test against the published KAT
// (post-quantum-cryptography/KAT, kat_MLKEM_768.rsp count=0): deterministic
// KeyGen(d,z) -> (ek,dk), Encaps(ek,msg) -> (ct,ss), Decaps round trip, and the
// implicit-reject case Decaps(dk, ct_n) -> ss_n.

///|
fn khex(s : String) -> Bytes {
  fn nib(c : Char) -> Int {
    let v = c.to_int()
    if v >= 0x30 && v <= 0x39 {
      v - 0x30
    } else if v >= 0x61 && v <= 0x66 {
      v - 0x61 + 10
    } else {
      abort("bad hex")
    }
  }

  let len = s.length() / 2
  let out = FixedArray::make(len, b'\x00')
  for i = 0; i < len; i = i + 1 {
    out[i] = ((nib(s.get_char(i * 2).unwrap()) << 4) |
    nib(s.get_char(i * 2 + 1).unwrap())).to_byte()
  }
  Bytes::makei(len, fn(j) { out[j] })
}

///|
fn beq(a : Bytes, b : Bytes) -> Bool {
  if a.length() != b.length() {
    return false
  }
  for i in 0..<a.length() {
    if a[i] != b[i] {
      return false
    }
  }
  true
}

///|
let kat_d : String = "6dbbc4375136df3b07f7c70e639e223e177e7fd53b161b3f4d57791794f12624"

///|
let kat_z : String = "f696484048ec21f96cf50a56d0759c448f3779752f0383d37449690694cf7a68"

///|
let kat_msg : String = "20a7b7e10f70496cc38220b944def699bf14d14e55cf4c90a12c1b33fc80ffff"

///|
let kat_pk : String = ""

///|
let kat_sk : String = ""

///|
let kat_ct : String = ""

///|
let kat_ss : String = "b408d5d115713f0a93047dbbea832e4340787686d59a9a2d106bd662ba0aa035"

///|
let kat_ct_n : String = ""

///|
let kat_ss_n : String = "e7bcf899feb5db69d11741a8838ecfee253e80b76d6a35af46e220e81dc41daf"

///|
test "ML-KEM-768 KeyGen(d,z) matches KAT ek/dk" {
  let (ek, dk) = @mlkem.keygen(khex(kat_d), khex(kat_z))
  inspect(ek.length(), content="1184")
  inspect(dk.length(), content="2400")
  inspect(beq(ek, khex(kat_pk)), content="true")
  inspect(beq(dk, khex(kat_sk)), content="true")
}

///|
test "ML-KEM-768 Encaps(ek,msg) matches KAT ct/ss" {
  let (ss, ct) = @mlkem.encaps(khex(kat_pk), khex(kat_msg))
  inspect(ct.length(), content="1088")
  inspect(beq(ct, khex(kat_ct)), content="true")
  inspect(beq(ss, khex(kat_ss)), content="true")
}

///|
test "ML-KEM-768 Decaps round trip + implicit reject" {
  let (ek, dk) = @mlkem.keygen(khex(kat_d), khex(kat_z))
  let _ = ek
  // valid ciphertext -> the encapsulated shared secret
  inspect(beq(@mlkem.decaps(dk, khex(kat_ct)), khex(kat_ss)), content="true")
  // corrupted ciphertext -> implicit-reject shared secret (KAT ss_n)
  inspect(
    beq(@mlkem.decaps(dk, khex(kat_ct_n)), khex(kat_ss_n)),
    content="true",
  )
}
